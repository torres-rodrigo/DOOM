# mako config — Generated by Matugen
# Structural settings + Material You colors

max-visible=5
sort=-time
layer=overlay
anchor=top-right

font=CaskaydiaCove NF 11
width=360
height=120
margin=12
padding=14
border-size=2
border-radius=10
icons=1
max-icon-size=48

default-timeout=8000
ignore-timeout=0

background-color={{colors.surface_container.default.hex}}
text-color={{colors.on_surface.default.hex}}
border-color={{colors.primary.default.hex}}

[urgency=low]
border-color={{colors.outline_variant.default.hex}}

[urgency=normal]
border-color={{colors.primary.default.hex}}

[urgency=high]
border-color={{colors.error.default.hex}}
background-color={{colors.error_container.default.hex}}
text-color={{colors.on_error_container.default.hex}}
