#!/bin/bash
# Display last package update date from pacman log

PACMAN_LOG="/var/log/pacman.log"

if [[ -f "$PACMAN_LOG" ]]; then
    # Extract the timestamp from the last "upgraded" entry
    LAST_UPGRADE=$(grep "upgraded" "$PACMAN_LOG" | tail -1 | sed -E 's/\[([^]]+)\].*/\1/')

    if [[ -n "$LAST_UPGRADE" ]]; then
        # Format the date in a human-readable format
        date -d "$LAST_UPGRADE" "+%A, %B %d %Y at %H:%M" 2>/dev/null || echo "unknown"
    else
        echo "no upgrades found"
    fi
else
    echo "pacman log not found"
fi
