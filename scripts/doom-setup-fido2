#!/bin/bash
set -euo pipefail

# FIDO2/Yubikey setup script (interactive)
# Based on omarchy implementation

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_success() { echo -e "${GREEN}$1${NC}"; }
print_error() { echo -e "${RED}$1${NC}"; }
print_info() { echo -e "${YELLOW}$1${NC}"; }

check_fido2_hardware() {
  tokens=$(fido2-token -L 2>/dev/null)
  if [ -z "$tokens" ]; then
    print_error "\nNo FIDO2 device detected. Please plug it in."
    return 1
  fi
  return 0
}

setup_pam_config() {
  local timestamp=$(date +%Y%m%d-%H%M%S)

  if ! grep -q pam_u2f.so /etc/pam.d/sudo; then
    print_info "Configuring sudo for FIDO2 authentication..."

    # Create backup
    sudo cp /etc/pam.d/sudo "/etc/pam.d/sudo.backup-${timestamp}"

    if [[ ! -f "/etc/pam.d/sudo.backup-${timestamp}" ]]; then
      print_error "Failed to create backup of /etc/pam.d/sudo"
      return 1
    fi

    sudo sed -i '1i auth    sufficient pam_u2f.so cue authfile=/etc/fido2/fido2' /etc/pam.d/sudo

    # Validate the change
    if ! grep -q pam_u2f.so /etc/pam.d/sudo; then
      print_error "Failed to modify /etc/pam.d/sudo"
      sudo cp "/etc/pam.d/sudo.backup-${timestamp}" /etc/pam.d/sudo
      return 1
    fi

    print_success "Created backup: /etc/pam.d/sudo.backup-${timestamp}"
  fi

  if [[ -f /etc/pam.d/polkit-1 ]] && ! grep -q 'pam_u2f.so' /etc/pam.d/polkit-1; then
    print_info "Configuring polkit for FIDO2 authentication..."

    # Create backup
    sudo cp /etc/pam.d/polkit-1 "/etc/pam.d/polkit-1.backup-${timestamp}"

    if [[ ! -f "/etc/pam.d/polkit-1.backup-${timestamp}" ]]; then
      print_error "Failed to create backup of /etc/pam.d/polkit-1"
      return 1
    fi

    sudo sed -i '1i auth      sufficient pam_u2f.so cue authfile=/etc/fido2/fido2' /etc/pam.d/polkit-1

    # Validate the change
    if ! grep -q pam_u2f.so /etc/pam.d/polkit-1; then
      print_error "Failed to modify /etc/pam.d/polkit-1"
      sudo cp "/etc/pam.d/polkit-1.backup-${timestamp}" /etc/pam.d/polkit-1
      return 1
    fi

    print_success "Created backup: /etc/pam.d/polkit-1.backup-${timestamp}"
  fi
}

remove_pam_config() {
  sudo sed -i '/pam_u2f\.so/d' /etc/pam.d/sudo
  [ -f /etc/pam.d/polkit-1 ] && sudo sed -i '/pam_u2f\.so/d' /etc/pam.d/polkit-1
}

if [[ "--remove" == "$1" ]]; then
  print_success "Removing FIDO2 authentication.\n"
  remove_pam_config
  sudo rm -rf /etc/fido2
  sudo pacman -Rns --noconfirm libfido2 pam-u2f
  print_success "FIDO2 authentication removed."
else
  print_success "Setting up FIDO2 device.\n"

  if ! check_fido2_hardware; then
    exit 1
  fi

  if [[ ! -f /etc/fido2/fido2 ]]; then
    sudo mkdir -p /etc/fido2
    print_success "\nTouch your FIDO2 key when it lights up...\n"

    # Use secure temporary file with restricted permissions
    TEMP_FIDO2="$(mktemp --tmpdir fido2-config.XXXXXX)"
    chmod 600 "$TEMP_FIDO2"

    # Cleanup on exit
    trap "rm -f $TEMP_FIDO2" EXIT

    if pamu2fcfg > "$TEMP_FIDO2"; then
      # Validate that credential was generated
      if [[ ! -s "$TEMP_FIDO2" ]]; then
        print_error "\nRegistration failed - no credential generated."
        exit 1
      fi

      sudo mv "$TEMP_FIDO2" /etc/fido2/fido2
      sudo chmod 644 /etc/fido2/fido2
      print_success "FIDO2 device registered!"
    else
      print_error "\nRegistration failed."
      rm -f "$TEMP_FIDO2"
      exit 1
    fi
  fi

  setup_pam_config

  print_success "\nFIDO2 authentication configured."
  print_info "Use your FIDO2 key for sudo and polkit."
fi
