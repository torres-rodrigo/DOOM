#!/bin/bash
set -euo pipefail

# Simple clipboard history manager using cliphist

# Check dependencies
if ! command -v cliphist &>/dev/null; then
    notify-send "Clipboard History" "cliphist is not installed" -t 2000 -u critical
    exit 1
fi

if ! command -v fzf &>/dev/null; then
    notify-send "Clipboard History" "fzf is not installed" -t 2000 -u critical
    exit 1
fi

if ! command -v wl-copy &>/dev/null; then
    notify-send "Clipboard History" "wl-clipboard is not installed" -t 2000 -u critical
    exit 1
fi

# Kill any existing fzf instance
pkill -f "fzf.*Clipboard" && exit 0

# Use cliphist with fzf and wl-copy
if cliphist list | fzf --prompt="Clipboard: " --border --height=40% | cliphist decode | wl-copy; then
    # Successfully copied to clipboard
    :
else
    # User cancelled or error occurred (exit code 130 is user cancel, that's OK)
    exit_code=$?
    if [[ $exit_code -ne 130 ]]; then
        notify-send "Clipboard History" "Failed to copy selection" -t 2000 -u normal
    fi
fi
