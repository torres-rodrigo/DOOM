#!/bin/bash
set -euo pipefail

# Full fingerprint setup script (interactive)
# Based on omarchy/dotfiles implementation

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_success() { echo -e "${GREEN}$1${NC}"; }
print_error() { echo -e "${RED}$1${NC}"; }
print_info() { echo -e "${YELLOW}$1${NC}"; }

check_fingerprint_hardware() {
  devices=$(fprintd-list "$USER" 2>/dev/null)
  if [[ -z "$devices" ]]; then
    print_error "\nNo fingerprint sensor detected."
    return 1
  fi
  return 0
}

setup_pam_config() {
  local timestamp=$(date +%Y%m%d-%H%M%S)

  # Configure sudo
  if ! grep -q pam_fprintd.so /etc/pam.d/sudo; then
    print_info "Configuring sudo for fingerprint authentication..."

    # Create backup
    sudo cp /etc/pam.d/sudo "/etc/pam.d/sudo.backup-${timestamp}"

    if [[ ! -f "/etc/pam.d/sudo.backup-${timestamp}" ]]; then
      print_error "Failed to create backup of /etc/pam.d/sudo"
      return 1
    fi

    sudo sed -i '1i auth    sufficient pam_fprintd.so' /etc/pam.d/sudo

    # Validate the change
    if ! grep -q pam_fprintd.so /etc/pam.d/sudo; then
      print_error "Failed to modify /etc/pam.d/sudo"
      sudo cp "/etc/pam.d/sudo.backup-${timestamp}" /etc/pam.d/sudo
      return 1
    fi

    print_success "Created backup: /etc/pam.d/sudo.backup-${timestamp}"
  fi

  # Configure polkit
  if [[ -f /etc/pam.d/polkit-1 ]] && ! grep -q 'pam_fprintd.so' /etc/pam.d/polkit-1; then
    print_info "Configuring polkit for fingerprint authentication..."

    # Create backup
    sudo cp /etc/pam.d/polkit-1 "/etc/pam.d/polkit-1.backup-${timestamp}"

    if [[ ! -f "/etc/pam.d/polkit-1.backup-${timestamp}" ]]; then
      print_error "Failed to create backup of /etc/pam.d/polkit-1"
      return 1
    fi

    sudo sed -i '1i auth      sufficient pam_fprintd.so' /etc/pam.d/polkit-1

    # Validate the change
    if ! grep -q pam_fprintd.so /etc/pam.d/polkit-1; then
      print_error "Failed to modify /etc/pam.d/polkit-1"
      sudo cp "/etc/pam.d/polkit-1.backup-${timestamp}" /etc/pam.d/polkit-1
      return 1
    fi

    print_success "Created backup: /etc/pam.d/polkit-1.backup-${timestamp}"
  fi
}

remove_pam_config() {
  sudo sed -i '/pam_fprintd\.so/d' /etc/pam.d/sudo
  [ -f /etc/pam.d/polkit-1 ] && sudo sed -i '/pam_fprintd\.so/d' /etc/pam.d/polkit-1
}

if [[ "--remove" == "$1" ]]; then
  print_success "Removing fingerprint authentication.\n"
  remove_pam_config
  sudo pacman -Rns --noconfirm fprintd
  print_success "Fingerprint authentication removed."
else
  print_success "Setting up fingerprint scanner.\n"

  if ! check_fingerprint_hardware; then
    exit 1
  fi

  setup_pam_config

  print_success "\nEnroll your fingerprint (move finger around sensor):\n"

  if sudo fprintd-enroll "$USER"; then
    print_success "\nFingerprint enrolled successfully!"

    print_info "\nVerifying...\n"
    if fprintd-verify; then
      print_success "\nFingerprint authentication configured."
      print_info "Use fingerprint for sudo, polkit, and hyprlock."
    fi
  fi
fi
